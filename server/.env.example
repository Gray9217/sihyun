MONGO_URI=mongodb://localhost:27017/someandssam
JWT_SECRET=your_jwt_secret_here
OPENAI_API_KEY=your_openai_api_key_here

# 카카오 로그인 (developers.kakao.com > 앱 > 플랫폼 키 > REST API 키)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_REDIRECT_URI=http://localhost:5000/auth/kakao/callback
KAKAO_LOGOUT_REDIRECT_URI=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# REST API 키 설정에서 클라이언트 시크릿 "사용 ON" 이면 아래도 입력
KAKAO_CLIENT_SECRET=your_client_secret_here

# 관리자(마스터) 계정 — 이 이메일로 가입/로그인하면 게시글 삭제 권한 부여 (여러 명: 쉼표로 구분)
ADMIN_EMAIL=your_admin_email@example.com

# === 팀 프로젝트 안내 ===
# 1. 이 파일(.env.example)만 공유하고, server/.env 는 절대 공유하지 마세요.
# 2. 로그인 상태는 브라우저(localStorage)에만 저장됩니다. 폴더를 보내도 친구 PC에 자동 로그인되지 않습니다.
# 3. MONGO_URI 를 팀 DB로 맞추면 회원/게시글 DB는 공유됩니다 (의도한 경우만).
# 4. 카카오 키는 팀이 하나의 개발용 앱을 공유해도 됩니다. 로그인은 각자 본인 카카오 계정으로 합니다.
